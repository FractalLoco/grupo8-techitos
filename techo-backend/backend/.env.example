# Servidor
PUERTO=3000

# PostgreSQL
DB_USUARIO=postgres
DB_HOST=localhost
DB_NOMBRE=techo
DB_CONTRASENA=tu_contrasena
DB_PUERTO=5432

# JWT
SECRETO_JWT=cambia_este_secreto

# Frontend (se usa para el enlace de inicio de sesión dentro del correo)
FRONTEND_URL=http://localhost:5173

# SMTP para envío automático de credenciales
# Ejemplo Gmail: CORREO_HOST=smtp.gmail.com, CORREO_PUERTO=465, CORREO_SEGURO=true
# En Gmail usa una contraseña de aplicación, no la contraseña normal de la cuenta.
CORREO_HOST=smtp.gmail.com
CORREO_PUERTO=465
CORREO_SEGURO=true
CORREO_USUARIO=tu_correo@gmail.com
CORREO_CONTRASENA=tu_contrasena_de_aplicacion
CORREO_REMITENTE=TECHO Chile <tu_correo@gmail.com>
